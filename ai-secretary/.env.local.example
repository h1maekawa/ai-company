# App auth (server-only — do NOT prefix with NEXT_PUBLIC_, it would leak to the browser bundle)
AUTH_PASSWORD=
SESSION_SECRET=

# Default provider
DEFAULT_PROVIDER=gemini
NEXT_PUBLIC_DEFAULT_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq fallback
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Ollama local optional
OLLAMA_URL=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_MS=60000

# Obsidian
VAULT_ROOT=/Users/maekawahiroyuki/Library/CloudStorage/Dropbox/maehiro/個人用/AI会社
